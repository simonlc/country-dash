{
  "name": "country-dash",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm i18n:compile && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "pnpm i18n:compile && tsc --noEmit",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@ebay/nice-modal-react": "^1.2.13",
    "@fontsource-variable/geist": "^5.2.8",
    "autosuggest-highlight": "^3.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "countries-list": "^3.3.0",
    "country-capitals": "^1.0.2",
    "country-state-city": "^3.2.1",
    "d3": "^7.9.0",
    "leva": "^0.10.1",
    "lucide-react": "^1.8.0",
    "match-sorter": "^8.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-feather": "^2.0.10",
    "shadcn": "^4.3.0",
    "solar-calculator": "^0.3",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@inlang/paraglide-js": "^2.16.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/autosuggest-highlight": "^3.2.3",
    "@types/d3": "^7.4.3",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/topojson-client": "^3.1.4",
    "@types/topojson-specification": "^1.0.5",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
